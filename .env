# Claude Code - OpenAI-compatible provider configuration
# Usage: node package/cli.js  (auto-loaded if you use dotenv or --env-file)
# Or:    node --env-file=.env package/cli.js

# ── Choose one provider, comment out the rest ────────────────────────────────

# DeepSeek
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_MODEL=deepseek-chat

# Groq
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your-groq-key
# OPENAI_MODEL=llama-3.3-70b-versatile

# Together AI
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_KEY=your-together-key
# OPENAI_MODEL=meta-llama/Llama-3-70b-chat-hf

# OpenAI
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=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
OPENAI_MODEL=minimaxai/minimax-m2.7

# Local Ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5-coder:32b

# ── Optional ──────────────────────────────────────────────────────────────────

# Proxy port (default: 19999)
# PROXY_PORT=19999
